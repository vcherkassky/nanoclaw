OLLAMA_HOST=
OLLAMA_CLASSIFIER_MODEL=
# Audio-capable Ollama model used to transcribe Telegram voice/audio
# attachments before they reach the agent. Defaults to gemma4:e4b.
TRANSCRIPTION_MODEL=
# Local proxy in front of Ollama that enforces a single loaded model
# (auto-evicts before swapping). NanoClaw starts it on this port at boot.
# OLLAMA_HOST should point at this port, not at real Ollama (11434).
OLLAMA_PROXY_PORT=11500
OLLAMA_REAL_HOST=http://127.0.0.1:11434
MONITOR_GMAIL_CREDENTIALS_DIR=
PUBLIC_INBOX_TARGET_JID=
MONITOR_PROCESSED_LABEL=
MONITOR_QUARANTINE_LABEL=
ASSISTANT_HAS_OWN_NUMBER=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
TELEGRAM_BOT_TOKEN=
